  "title": "Building Sentences & Doing",
  "subtitle": "Verbs, having, and there is: putting words together",
  "sections": [
    {
      "id": "myday",
      "icon": "☀️",
      "title": "My day",
      "subtitle": "Il-ġurnata tiegħi: a daily routine",
      "intro": "A short run through an ordinary day.",
      "dialogue": [
        {
          "mt": "X'tagħmel filgħodu?",
          "en": "What do you do in the morning?"
        },
        {
          "mt": "Nqum kmieni u nixrob kapuċċino.",
          "en": "I get up early and drink a cappuccino."
        },
        {
          "mt": "U wara?",
          "en": "And after?"
        },
        {
          "mt": "Immur naħdem sas-sitta.",
          "en": "I go to work until six."
        },
        {
          "mt": "Filgħaxija?",
          "en": "In the evening?"
        },
        {
          "mt": "Niekol id-dar u naqra ktieb.",
          "en": "I eat at home and read a book."
        }
      ]
    },
