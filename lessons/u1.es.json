    {
      "id": "grammar",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "L-artiklu: saying 'the' in Maltese",
      "intro": "En maltés hay una sola palabra para 'el / la', pero cambia de forma para adaptarse a la palabra que la sigue; la forma que uses depende completamente del primer sonido de esa palabra. Se divide en tres grupos ordenados.",
      "rules": [
        {
          "id": "moon",
          "title": "Cuando 'el/la' es simplemente il-",
