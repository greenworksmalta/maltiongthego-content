      "dialogue": [
        {
          "mt": "Skużani — ma nitkellimx Malti tajjeb. Titkellem bl-Ingliż?",
          "en": "Sorry — I don't speak Maltese well. Do you speak English?"
        },
        {
          "mt": "Iva, ftit. Kif nista' ngħinek?",
          "en": "Yes, a little. How can I help you?"
        },
        {
          "mt": "Tista' tirrepeti, bil-mod jekk jogħġbok?",
          "en": "Can you repeat, slowly please?"
        },
        {
          "mt": "Mhux problema. Hekk hu...",
          "en": "No problem. Like this..."
        }
