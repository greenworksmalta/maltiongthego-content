    {
      "id": "grammar5",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: people, pointing and belonging",
      "intro": "Pronouns stand in for names; demonstratives point; and two tools show who owns what.",
      "rules": [
        {
          "id": "ta-possessive",
          "title": "Possessive with ta' (of)",
          "explanation": "The simplest way to show possession: noun + ta' + owner. Literally 'X of Y'. Use 'ta'' for any owner, names, family members, things.",
          "examples": [
            {
              "mt": "Il-kelb ta' Joseph",
              "en": "Joseph's dog"
            },
            {
              "mt": "Il-pupa ta' Joanne",
              "en": "Joanne's doll"
            },
            {
              "mt": "Il-ktieb ta' Karl",
              "en": "Karl's book"
            },
            {
              "mt": "Il-basket ta' Mary",
              "en": "Mary's bag"
            },
            {
              "mt": "Ir-rota ta' Joanne",
              "en": "Joanne's bike"
            },
            {
              "mt": "It-tfal ta' Mary",
              "en": "Mary's children"
            }
          ]
        },
        {
          "id": "possessive-pronouns",
          "title": "Possessive pronouns: tiegħi, tiegħek, tiegħu…",
          "explanation": "When the owner is a pronoun (my, your, his, her…), use one of these standalone words AFTER the noun. They agree with the OWNER, not the noun.",
          "letters": [
            "Tiegħi",
            "Tiegħek",
            "Tiegħu",
            "Tagħha",
            "Tagħna",
            "Tagħkom",
            "Tagħhom"
          ],
          "examples": [
            {
              "mt": "Il-kelb tiegħi",
              "en": "My dog"
            },
            {
