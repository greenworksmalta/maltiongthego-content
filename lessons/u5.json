              "mt": "missier → missirijiet",
              "en": "father → fathers"
            },
            {
              "mt": "nanna → nanniet",
              "en": "grandmother → grandmothers"
            },
            {
              "mt": "iben/bint → ulied",
              "en": "son/daughter → children (shared plural)"
            },
            {
              "mt": "ziju/zija → zijiet",
              "en": "uncle/aunt → uncles & aunts"
            },
            {
              "mt": "kuġin/kuġina → kuġini",
              "en": "cousin → cousins"
            },
            {
              "mt": "għarus/għarusa → għarajjes",
              "en": "fiancé/fiancée → engaged couples"
