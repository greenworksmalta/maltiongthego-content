    {
      "id": "grammar7",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: asking and finding your way",
      "intro": "The question words, and the polite way to ask for directions.",
      "rules": [
        {
          "id": "wh-questions",
          "title": "The asking words",
          "explanation": "The question starters you need for almost anything: Min (who), Fejn (where), Xiex (what), Meta (when), Għaliex (why), Liema (which), Kif (how). Most go right at the front.",
          "letters": [
            "Min?",
            "Fejn?",
            "Xi?/Xiex?",
            "Għaliex?/Għala?",
            "Meta?",
            "Liema?",
            "Ta' min?",
            "Kif?"
          ],
          "examples": [
            {
              "mt": "Min hu l-missierek?",
              "en": "Who is your father?"
            },
            {
              "mt": "Fejn mort?",
              "en": "Where did you go?"
            },
            {
              "mt": "Xi trid tixrob, kapuċċino jew te?",
              "en": "What do you want to drink, a cappuccino or tea?"
            },
            {
              "mt": "Għaliex wasalt tard?",
              "en": "Why did you arrive late?"
            },
            {
              "mt": "Meta jiftaħ il-ħanut?",
              "en": "When does the shop open?"
            },
            {
              "mt": "Liema triq twassal il-Belt?",
              "en": "Which road leads to Valletta?"
            },
            {
              "mt": "Ta' min hu dan il-lapes?",
              "en": "Whose pencil is this?"
            },
            {
              "mt": "Kif immorru l-ajruport?",
              "en": "How do we get to the airport?"
            }
          ]
        },
        {
          "id": "polite-request",
          "title": "Asking the way, politely",
          "explanation": "A reliable opener: Skużi. Tista' tgħidli fejn hi…?, jekk jogħġbok. Match hi/hu to the place (hi for l-iskola, hu for il-bank). Close with Grazzi.",
          "examples": [
            {
              "mt": "Skużi. Tista' tgħidli fejn hi l-iskola, jekk jogħġbok?",
              "en": "Excuse me. Can you tell me where the school is, please? (f.)"
            },
            {
              "mt": "Skużi. Tista' tgħidli fejn hu l-isptar, jekk jogħġbok?",
              "en": "Excuse me. Can you tell me where the hospital is, please? (m.)"
            },
            {
              "mt": "Bonġu. Kif nista' nasal il-bank, jekk jogħġbok?",
              "en": "Good morning. How can I get to the bank, please?"
            },
            {
              "mt": "Ibqa' sejjer dritt u taraha fuq il-lemin",
              "en": "Keep going straight and you'll see it on the right"
            },
            {
              "mt": "Grazzi ħafna",
              "en": "Thank you very much"
            }
          ]
        }
      ]
    },
