    {
      "id": "lost",
      "icon": "🧭",
      "title": "Cómo orientarte",
      "subtitle": "Mitluf?: pedir indicaciones",
      "intro": "Preguntarle a un transeúnte cómo llegar a algún lugar.",
      "dialogue": [
        {
          "mt": "Skużi, fejn hu l-bank?",
          "en": "Disculpe, ¿dónde está el banco?"
        },
        {
          "mt": "Mur dritt, imbagħad dur fuq il-lemin.",
          "en": "Siga recto, luego doble a la derecha."
        },
        {
          "mt": "Hu 'l bogħod?",
          "en": "¿Está lejos?"
        },
        {
          "mt": "Le, ħames minuti biss.",
          "en": "No, solo cinco minutos."
        },
        {
          "mt": "Grazzi ħafna!",
          "en": "¡Muchas gracias!"
        }
      ]
    },
    {
      "id": "questions",
