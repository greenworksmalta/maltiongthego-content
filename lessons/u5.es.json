      "title": "Hablar de la familia",
      "subtitle": "Nitkellmu fuq il-familja",
      "intro": "Una charla rápida sobre quién forma parte de tu familia.",
      "dialogue": [
        {
          "mt": "Għandek familja kbira?",
          "en": "¿Tienes una familia grande?"
        },
        {
          "mt": "Iva, għandi żewġt aħwa.",
          "en": "Sí, tengo dos hermanos."
        },
        {
          "mt": "Subien jew bniet?",
          "en": "¿Niños o niñas?"
        },
        {
          "mt": "Ħija u oħti. U int?",
          "en": "Mi hermano y mi hermana. ¿Y tú?"
        },
        {
          "mt": "Jien għandi tifel wieħed.",
          "en": "Yo tengo un hijo."
        },
        {
          "mt": "Kemm għandu żmien?",
          "en": "¿Cuántos años tiene?"
        },
        {
          "mt": "Għandu ħames snin.",
          "en": "Tiene cinco años."
        }
      ]
    },
