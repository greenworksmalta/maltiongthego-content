      "id": "meeting",
      "icon": "👋",
      "title": "Meeting someone",
      "subtitle": "Tiltaqa' man-nies: saying hello and introducing yourself",
      "intro": "A first chat with a new neighbour.",
      "dialogue": [
        {
          "mt": "Bonġu! Jien Mary, ġara ġdida hawn.",
          "en": "Good morning! I'm Mary, a new neighbour here."
        },
        {
          "mt": "Bonġu Mary! Jien Joseph. Merħba!",
          "en": "Good morning Mary! I'm Joseph. Welcome!"
        },
        {
          "mt": "Għandi pjaċir. Int minn hawn?",
          "en": "Nice to meet you. Are you from here?"
        },
        {
          "mt": "Iva, jien Malti. U int, minn fejn int?",
          "en": "Yes, I'm Maltese. And you, where are you from?"
        },
        {
          "mt": "Jien Ingliża, imma issa ngħix Malta.",
          "en": "I'm English, but now I live in Malta."
        },
        {
          "mt": "Tajjeb, merħba f'Malta!",
          "en": "Good, welcome to Malta!"
        }
      ]
    },
