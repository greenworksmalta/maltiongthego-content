    {
      "id": "grammar9",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: the time, and asking the price",
      "intro": "How the clock works in Maltese, and the two 'how much' questions.",
      "rules": [
        {
          "id": "telling-time",
          "title": "The time: u (past) and nieqes (to)",
          "explanation": "Ask X'ħin hu? (what time is it?). The hour takes the article: Is-siegħa (1:00), Is-sitta (6:00). Add minutes with u (past) or nieqes (to). When you give the minutes as a number, add minuta after it: Is-sitta u tletin minuta (6:30), Il-ħamsa u ħmistax-il minuta (5:15), Id-disgħa nieqes kwart (8:45).",
          "examples": [
            {
              "mt": "X'ħin hu?",
              "en": "What time is it?"
            },
            {
              "mt": "Is-sitta u tletin minuta.",
              "en": "Half past six."
            },
            {
              "mt": "Il-ħamsa u ħmistax-il minuta.",
              "en": "Quarter past five."
            },
            {
              "mt": "Id-disgħa nieqes kwart.",
              "en": "Quarter to nine."
            }
          ]
        },
        {
          "id": "how-much",
          "title": "Two ways to ask the price",
          "explanation": "Use Kemm jiswa? for one thing (how much is it?) and Kemm huma? for more than one (how much are they?). Answer with the number plus ewro or ċenteżmu.",
          "examples": [
            {
              "mt": "Kemm jiswa dan?",
              "en": "How much is this?"
            },
            {
              "mt": "Kemm huma t-tadam?",
              "en": "How much are the tomatoes?"
            },
            {
              "mt": "Żewġ ewro u ħamsin ċenteżmu.",
              "en": "Two euro fifty."
            }
          ]
        }
      ],
      "exercises": [
        {
          "id": "timemc",
          "type": "mc",
          "choices": [
            "u",
            "nieqes"
          ],
          "items": [
            {
              "word": "Is-sitta ___ tletin minuta (6:30)",
              "answer": "u",
              "en": "half past six",
              "mt": "Is-sitta u tletin minuta"
            },
            {
              "word": "Il-ħamsa ___ ħmistax-il minuta (5:15)",
              "answer": "u",
              "en": "quarter past five",
              "mt": "Il-ħamsa u ħmistax-il minuta"
            },
            {
              "word": "Id-disgħa ___ kwart (8:45)",
              "answer": "nieqes",
              "en": "quarter to nine",
              "mt": "Id-disgħa nieqes kwart"
            }
          ],
          "opts": {
            "rawPrompt": true,
            "audioAnswer": true
          }
        }
      ]
    },
