{
  "id": "u5",
  "title": "People, Family & Belonging",
  "subtitle": "Pronouns, family, this and that, who owns what",
  "sections": [
    {
      "id": "familytalk",
      "icon": "👪",
      "title": "Talking about family",
      "subtitle": "Nitkellmu fuq il-familja",
      "intro": "A quick chat about who's in your family.",
      "dialogue": [
        {
          "mt": "Għandek familja kbira?",
          "en": "Do you have a big family?"
        },
        {
          "mt": "Iva, għandi żewġt aħwa.",
          "en": "Yes, I have two siblings."
        },
        {
          "mt": "Subien jew bniet?",
          "en": "Boys or girls?"
        },
        {
          "mt": "Ħija u oħti. U int?",
          "en": "My brother and my sister. And you?"
        },
        {
          "mt": "Jien għandi tifel wieħed.",
          "en": "I have one son."
        },
        {
          "mt": "Kemm għandu żmien?",
          "en": "How old is he?"
        },
        {
          "mt": "Għandu ħames snin.",
          "en": "He's five years old."
        }
      ]
    },
    {
      "id": "pronouns",
