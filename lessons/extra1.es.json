    {
      "id": "grammarwelcome",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika — las pocas reglas detrás de toda esta lección",
      "intro": "Cinco mini-reglas que abren todo lo que acabas de ver. No intentes memorizarlas — simplemente fíjate en los patrones; las lecciones del curso profundizan más.",
      "rules": [
        {
          "id": "nixtieq-pattern",
          "title": "Nixtieq + cosa = 'Quisiera…'",
          "explanation": "La forma cortés y universal de pedir algo. 'Nixtieq' por sí solo = 'quisiera'. Añade lo que quieres justo después. Termina con 'jekk jogħġbok' para sonar aún más educado.",
          "examples": [
            {
              "mt": "Nixtieq kapuċċino",
              "en": "Quisiera un capuchino"
            },
            {
              "mt": "Nixtieq ilma bil-lumi",
              "en": "Quisiera agua con limón"
            },
            {
              "mt": "Nixtieq dan, jekk jogħġbok",
              "en": "Quisiera esto, por favor"
            },
            {
              "mt": "Nixtieq pastizz",
              "en": "Quisiera un pastizz"
            }
          ]
        },
        {
          "id": "bil-with",
          "title": "bil- = 'con el/la' (y biz- antes de z)",
          "explanation": "'bi' (con) se fusiona con el artículo 'il-' formando 'bil-' — se usa al pedir bebidas 'con' algo. Antes de palabras que empiezan por z, se vuelve 'biz-' (regla de consonante 'Xemxin' de la Lección 1).",
          "letters": [
            "bil-",
            "biz-"
          ],
          "examples": [
            {
              "mt": "Kapuċċino bil-ħalib",
              "en": "Capuchino con leche"
            },
            {
              "mt": "Ilma bil-lumi",
              "en": "Agua con limón"
            },
            {
              "mt": "Kapuċċino biz-zokkor",
              "en": "Capuchino con azúcar"
            },
            {
              "mt": "Bil-flus / Bil-karta",
              "en": "En efectivo / con tarjeta"
            }
          ]
        },
        {
          "id": "kemm-jiswa",
          "title": "Kemm jiswa? = '¿Cuánto cuesta?'",
          "explanation": "'Kemm?' = '¿cuánto / cuántos?'. Júntalo con 'jiswa' (cuesta) para UN artículo, 'jiswew' (cuestan) para varios. Mismo patrón para cualquier pregunta de '¿cuánto?'.",
          "examples": [
            {
              "mt": "Kemm jiswa dan?",
              "en": "¿Cuánto cuesta esto? (un artículo)"
            },
            {
              "mt": "Kemm jiswew dawn?",
              "en": "¿Cuánto cuestan estos? (varios)"
            },
            {
              "mt": "Żewġ ewro u sebgħin ċenteżmu",
              "en": "Dos euros setenta"
            },
            {
              "mt": "Erbgħa u disgħin ewro",
              "en": "Noventa y cuatro euros"
            }
          ]
        },
        {
          "id": "polite-formulas",
          "title": "Apilar palabras de cortesía",
          "explanation": "La cortesía en maltés viene de APILAR palabras cortas. 'Grazzi' sola está bien. 'Grazzi ħafna' (muchas gracias) suena más cálido. 'Jekk jogħġbok' (por favor) se pega a casi cualquier petición. 'Skużani' (perdón/disculpa) abre una petición a alguien desconocido. Cuanto más apilas, más educado.",
          "examples": [
            {
              "mt": "Grazzi",
              "en": "Gracias"
            },
            {
              "mt": "Grazzi ħafna",
              "en": "Muchas gracias"
            },
            {
              "mt": "Skużani, tista' tgħinni?",
              "en": "Disculpa, ¿puedes ayudarme?"
            },
            {
              "mt": "Iva, jekk jogħġbok",
              "en": "Sí, por favor"
            },
            {
              "mt": "Le grazzi",
              "en": "No gracias"
            }
          ]
        },
        {
          "id": "language-help",
          "title": "Cambiar al inglés con educación",
          "explanation": "En Malta casi todos hablan muy bien inglés — siempre puedes cambiar. Pero empezar con una de estas frases en maltés te gana muchísima simpatía antes de hacerlo.",
          "examples": [
            {
              "mt": "Nitkellem ftit Malti",
              "en": "Hablo un poco de maltés"
            },
            {
              "mt": "Qed nitgħallem il-Malti",
              "en": "Estoy aprendiendo maltés"
            },
            {
              "mt": "Titkellem bl-Ingliż?",
              "en": "¿Hablas inglés?"
            },
            {
              "mt": "Tista' tirrepeti, bil-mod jekk jogħġbok?",
              "en": "¿Puedes repetir, despacio por favor?"
            }
          ]
        }
      ]
    },
