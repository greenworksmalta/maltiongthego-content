    {
      "id": "grammar9",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: la hora y preguntar el precio",
      "intro": "Cómo funciona el reloj en maltés y las dos formas de preguntar el precio.",
      "rules": [
        {
          "id": "telling-time",
          "title": "La hora: u (y) y nieqes (menos)",
          "explanation": "Pregunta X'ħin hu? (¿qué hora es?). La hora lleva el artículo: Is-siegħa (1:00), Is-sitta (6:00). Añade los minutos con u (y) o nieqes (menos). Cuando das los minutos como número, añade minuta después: Is-sitta u tletin minuta (6:30), Il-ħamsa u ħmistax-il minuta (5:15), Id-disgħa nieqes kwart (8:45).",
          "examples": [
            {
              "mt": "X'ħin hu?",
              "en": "¿Qué hora es?"
            },
            {
              "mt": "Is-sitta u tletin minuta.",
              "en": "Las seis y media."
            },
            {
              "mt": "Il-ħamsa u ħmistax-il minuta.",
              "en": "Las cinco y cuarto."
            },
            {
              "mt": "Id-disgħa nieqes kwart.",
              "en": "Las nueve menos cuarto."
            }
          ]
        },
        {
          "id": "how-much",
          "title": "Dos formas de preguntar el precio",
          "explanation": "Usa Kemm jiswa? para una sola cosa (¿cuánto cuesta?) y Kemm huma? para más de una (¿cuánto cuestan?). Responde con el número más ewro o ċenteżmu.",
          "examples": [
            {
              "mt": "Kemm jiswa dan?",
              "en": "¿Cuánto cuesta esto?"
            },
            {
              "mt": "Kemm huma t-tadam?",
              "en": "¿Cuánto cuestan los tomates?"
            },
            {
              "mt": "Żewġ ewro u ħamsin ċenteżmu.",
              "en": "Dos euros con cincuenta."
            }
          ]
        }
      ],
      "exercises": [
        {
          "id": "timemc",
          "type": "mc",
          "choices": [
            "u",
            "nieqes"
          ],
          "items": [
            {
              "word": "Is-sitta ___ tletin minuta (6:30)",
              "answer": "u",
              "en": "las seis y media",
