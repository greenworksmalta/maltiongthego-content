    {
      "id": "grammar",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "L-artiklu: saying 'the' in Maltese",
      "intro": "There's one word for 'the' in Maltese, but it reshapes to fit the word in front of it, and which shape you use is decided entirely by that word's first sound. It sorts into three tidy groups.",
      "rules": [
        {
          "id": "moon",
          "title": "When 'the' is just il-",
          "explanation": "Most consonants are easy: 'the' is simply il-, no change. Maltese files these as the 'Qamrin' consonants. So: il-ktieb, il-baħar, il-qalb.",
          "letters": [
            "b",
            "f",
            "ġ",
            "g",
            "ħ",
            "j",
            "k",
            "l",
            "m",
            "p",
            "q",
            "v",
            "w"
          ],
          "examples": [
            {
              "word": "ktieb",
              "article": "il-",
              "full": "il-ktieb",
              "en": "the book"
            },
            {
              "word": "baħar",
              "article": "il-",
              "full": "il-baħar",
              "en": "the sea"
            },
            {
              "word": "ġnien",
              "article": "il-",
              "full": "il-ġnien",
              "en": "the garden"
            },
            {
              "word": "qalb",
              "article": "il-",
              "full": "il-qalb",
              "en": "the heart"
            },
            {
              "word": "warda",
              "article": "il-",
              "full": "il-warda",
              "en": "the rose"
            }
