{
  "id": "u7",
  "title": "Asking Questions & Directions",
  "subtitle": "Question words, directions, finding your way",
  "sections": [
    {
      "id": "lost",
      "icon": "🧭",
      "title": "Finding your way",
      "subtitle": "Mitluf?: asking for directions",
      "intro": "Asking a passer-by how to get somewhere.",
      "dialogue": [
        {
          "mt": "Skużi, fejn hu l-bank?",
          "en": "Excuse me, where is the bank?"
        },
        {
          "mt": "Mur dritt, imbagħad dur fuq il-lemin.",
          "en": "Go straight, then turn right."
        },
        {
          "mt": "Hu 'l bogħod?",
          "en": "Is it far?"
        },
        {
          "mt": "Le, ħames minuti biss.",
          "en": "No, just five minutes."
        },
        {
          "mt": "Grazzi ħafna!",
          "en": "Thank you very much!"
        }
      ]
    },
    {
      "id": "questions",
      "icon": "❓",
      "title": "Wh-questions",
      "subtitle": "Mistoqsijiet: asking who, what, when, where, why",
      "intro": "The question words (who, what, where, when, why, how) and how to use them.",
      "items": [
        {
          "mt": "Min?",
          "en": "Who?",
          "icon": "🧑",
          "example": "Min hu l-għalliem tiegħek?",
          "example_en": "Who is your teacher?"
        },
        {
          "mt": "Fejn?",
          "en": "Where?",
          "icon": "📍",
          "example": "Fejn toqgħod?",
          "example_en": "Where do you live?"
        },
        {
          "mt": "Xi?",
          "alt": "Xiex?",
          "en": "What?/How many?",
          "icon": "❓",
          "example": "X'tieħu?",
          "example_en": "What will you have?"
        },
        {
          "mt": "Għaliex?",
          "alt": "Għala?",
          "en": "Why?",
          "icon": "🤔",
          "example": "Għaliex int hawn?",
          "example_en": "Why are you here?"
        },
        {
          "mt": "Meta?",
          "en": "When?",
          "icon": "🕐",
          "example": "Meta ġej il-vapur?",
          "example_en": "When does the ship arrive?"
        },
        {
          "mt": "Liema?",
          "en": "Which?",
          "icon": "👆",
          "example": "Liema tip ta' kapuċċino trid?",
          "example_en": "Which kind of cappuccino do you want?"
        },
        {
          "mt": "Ta' min?",
          "en": "Whose?",
          "icon": "🔑",
          "example": "Ta' min hi din il-borża?",
          "example_en": "Whose bag is this?"
        },
        {
          "mt": "Kif?",
          "en": "How?",
          "icon": "💡",
          "example": "Kif tasal hemm?",
          "example_en": "How do you get there?"
        }
      ],
      "passage": {
        "title": "Read and answer",
        "lines": [
          {
            "mt": "Nhar il-Ħamis, Joanne u Karl marru jieklu f'ristorant fl-Imdina.",
            "en": "On Thursday, Joanne and Karl went to eat at a restaurant in Mdina."
          },
          {
            "mt": "Bdew bi platt timpana u soppa tal-armla.",
            "en": "They started with a plate of timpana and widow's soup."
          },
          {
            "mt": "Karl ipprova l-fenek għall-ewwel darba u tant ħa pjaċir bih.",
            "en": "Karl tried rabbit for the first time and enjoyed it a lot."
          },
          {
            "mt": "Wara, qassmu kannol u ħadu kapuċċino.",
            "en": "Afterwards, they shared a cannolo and took a cappuccino."
          },
          {
            "mt": "Il-wejter qalilhom: 'Saħħa! Erġgħu lura għada.'",
            "en": "The waiter told them: 'Cheers! Come back tomorrow.'"
          }
        ],
        "questions": [
          {
            "q": "Fejn marru Joanne u Karl?",
            "qen": "Where did Joanne and Karl go?",
            "a": "Marru f'ristorant fl-Imdina.",
            "aen": "They went to a restaurant in Mdina."
          },
          {
            "q": "Min ipprova l-fenek?",
            "qen": "Who tried the rabbit?",
            "a": "Karl ipprova l-fenek.",
            "aen": "Karl tried the rabbit."
          },
          {
            "q": "Meta marru jieklu?",
            "qen": "When did they go to eat?",
            "a": "Marru nhar il-Ħamis.",
            "aen": "They went on Thursday."
          },
          {
            "q": "X' qasmu wara?",
            "qen": "What did they share afterwards?",
            "a": "Qassmu kannol.",
            "aen": "They shared a cannolo."
          }
        ]
      }
    },
