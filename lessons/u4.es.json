    {
      "id": "grammar4",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: making words match",
      "intro": "En maltés, las palabras que rodean a un sustantivo se adaptan a él. Así funcionan los colores y los adjetivos, y el género que hay detrás.",
      "rules": [
        {
          "id": "noun-gender",
          "title": "Cada sustantivo es masculino o femenino",
          "explanation": "El maltés no tiene neutro; una mesa, un carro, un libro son cada uno masculino o femenino, y esa elección se extiende a las palabras que los rodean. Guía básica: -a tiende a ser femenino (mara, karozza); la mayoría de las otras terminaciones son masculinas (raġel, ktieb).",
          "examples": [
            {
              "mt": "raġel",
              "en": "hombre (m)"
            },
            {
              "mt": "kelb",
              "en": "perro (m)"
            },
            {
              "mt": "nannu",
              "en": "abuelo (m, -u)"
            },
            {
              "mt": "ktieb",
              "en": "libro (m)"
            },
            {
              "mt": "mara",
              "en": "mujer (f, -a)"
            },
            {
              "mt": "kelba",
              "en": "perra (f, -a)"
            },
            {
              "mt": "tazza",
              "en": "vaso (f, -a)"
            },
            {
              "mt": "karozza",
              "en": "carro (f, -a)"
            }
          ]
        },
        {
          "id": "adjective-agreement",
          "title": "Los adjetivos cambian para concordar",
          "explanation": "Un adjetivo copia su sustantivo: forma base para masculino, +a para femenino, forma especial para plural. Alto → raġel twil / mara twila / tfal twal. Y siempre va después del sustantivo, no antes.",
          "examples": [
            {
              "mt": "raġel twil",
              "en": "un hombre alto (m)"
            },
            {
              "mt": "mara twila",
              "en": "una mujer alta (f)"
            },
            {
              "mt": "tfal twal",
              "en": "niños altos (pl)"
            },
            {
              "mt": "ġnien sabiħ",
              "en": "un jardín hermoso (m)"
            },
            {
              "mt": "fjura sabiħa",
              "en": "una flor hermosa (f)"
            },
            {
              "mt": "fjuri sbieħ",
              "en": "flores hermosas (pl)"
            }
          ]
        },
        {
          "id": "colour-agreement",
          "title": "Los colores también concuerdan",
          "explanation": "Los colores son simplemente adjetivos: kelb abjad / karozza bajda / ħitan bojod. Algunos tomados del italiano (blu, roża, vjola, kannella) nunca cambian; son fáciles de recordar.",
          "letters": [
            "Abjad/Bajda/Bojod",
            "Iswed/Sewda/Suwed",
            "Aħmar/Ħamra/Ħomor",
            "Isfar/Safra/Sofor",
            "Aħdar/Ħadra/Ħodor"
          ],
          "examples": [
            {
              "mt": "kelb abjad",
              "en": "un perro blanco (m)"
            },
            {
              "mt": "karozza bajda",
              "en": "un carro blanco (f)"
            },
            {
              "mt": "ħitan bojod",
              "en": "paredes blancas (pl)"
            },
            {
              "mt": "ballun aħmar",
              "en": "un balón rojo (m)"
            },
            {
              "mt": "tuffieħa ħamra",
              "en": "una manzana roja (f)"
            },
