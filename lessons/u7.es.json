          "example_en": "¿Qué vas a tomar?",
          "icon": "❓"
        },
        {
          "mt": "Għaliex?",
          "alt": "Għala?",
          "en": "¿Por qué?",
          "example": "Għaliex int hawn?",
          "example_en": "¿Por qué estás aquí?",
          "icon": "🤔"
        },
        {
          "mt": "Meta?",
          "en": "¿Cuándo?",
          "example": "Meta ġej il-vapur?",
          "example_en": "¿Cuándo llega el barco?",
