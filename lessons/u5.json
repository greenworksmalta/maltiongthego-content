          "en": "She",
          "icon": "👩"
        },
        {
          "mt": "Aħna",
          "alt": "Aħna",
          "en": "We",
          "icon": "👥"
        },
        {
          "mt": "Intom",
          "alt": "Intom",
          "en": "You (plural)",
          "icon": "🫂"
