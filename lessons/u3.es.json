    {
      "id": "grammarhelp",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: being polite and asking for help",
      "intro": "Dos pequeños hábitos cubren la mayor parte de la cortesía maltesa: apilar palabras cortas de cortesía y la petición con \"Tista'...?\".",
      "rules": [
        {
          "id": "polite-formulas",
          "title": "La cortesía es acumulación",
          "explanation": "El maltés se vuelve más cortés apilando palabras cortas. Grazzi está bien; Grazzi ħafna es más cálido; empieza con Skużani con un desconocido y cierra con jekk jogħġbok. Apila tanto como el momento lo requiera.",
          "examples": [
            {
              "mt": "Grazzi",
              "en": "Gracias"
            },
            {
              "mt": "Grazzi ħafna",
              "en": "Muchas gracias"
            },
            {
              "mt": "Skużani, tista' tgħinni?",
              "en": "Disculpa, ¿puedes ayudarme?"
            },
            {
              "mt": "Iva, jekk jogħġbok",
              "en": "Sí, por favor"
            },
            {
              "mt": "Le grazzi",
              "en": "No, gracias"
            }
          ]
        },
        {
          "id": "language-help",
          "title": "Gánate una sonrisa, luego cambia de idioma",
          "explanation": "Casi todos aquí hablan muy bien inglés, así que siempre puedes cambiarte, pero empezar con una frase en maltés (Qed nitgħallem il-Malti) genera una buena impresión de verdad.",
          "examples": [
            {
              "mt": "Nitkellem ftit Malti",
              "en": "Hablo un poco de maltés"
            },
            {
              "mt": "Qed nitgħallem il-Malti",
              "en": "Estoy aprendiendo maltés"
            },
            {
              "mt": "Titkellem bl-Ingliż?",
              "en": "¿Hablas inglés?"
            },
            {
              "mt": "Tista' tirrepeti, bil-mod jekk jogħġbok?",
              "en": "¿Puedes repetir, despacio por favor?"
            }
          ]
        },
        {
          "id": "tista-requests",
          "title": "Pedir con 'Tista'…?'",
          "explanation": "Tista' es simplemente la forma 'tú' de 'poder'. Pon cualquier verbo cotidiano después para hacer una petición cortés: Tista' tgħinni? (¿Puedes ayudarme?), Tista' tirrepeti? (¿Puedes repetir?), Tista' tiktibha? (¿Puedes escribirlo?). El conjunto completo es nista' (yo puedo), tista' (tú puedes), jista' (él puede).",
          "examples": [
            {
              "mt": "Tista' tgħinni?",
              "en": "¿Puedes ayudarme?"
            },
            {
              "mt": "Tista' tirrepeti?",
              "en": "¿Puedes repetir?"
            },
            {
              "mt": "Tista' tiktibha?",
              "en": "¿Puedes escribirlo?"
            }
          ]
        }
      ]
    },
