        },
        {
          "mt": "Liema?",
          "en": "¿Cuál?",
          "example": "Liema tip ta' kapuċċino trid?",
          "example_en": "¿Qué tipo de capuchino quieres?",
          "icon": "👆"
        },
        {
          "mt": "Ta' min?",
          "en": "¿De quién?",
          "example": "Ta' min hi din il-borża?",
          "example_en": "¿De quién es esta bolsa?",
          "icon": "🔑"
        },
        {
          "mt": "Kif?",
          "en": "¿Cómo?",
          "example": "Kif tasal hemm?",
          "example_en": "¿Cómo llegas allí?",
          "icon": "💡"
        }
      ],
      "passage": {
        "title": "Lee y responde",
        "lines": [
          {
            "mt": "Nhar il-Ħamis, Joanne u Karl marru jieklu f'ristorant fl-Imdina.",
            "en": "El jueves, Joanne y Karl fueron a comer a un restaurante en Mdina."
          },
          {
            "mt": "Bdew bi platt timpana u soppa tal-armla.",
            "en": "Empezaron con un plato de timpana y soppa tal-armla."
          },
          {
            "mt": "Karl ipprova l-fenek għall-ewwel darba u tant ħa pjaċir bih.",
            "en": "Karl probó el conejo por primera vez y le encantó."
          },
          {
            "mt": "Wara, qassmu kannol u ħadu kapuċċino.",
            "en": "Después compartieron un cannolo y tomaron un capuchino."
          },
          {
            "mt": "Il-wejter qalilhom: 'Saħħa! Erġgħu lura għada.'",
            "en": "El mesero les dijo: '¡Saħħa! Vuelvan mañana.'"
          }
        ],
        "questions": [
          {
            "q": "Fejn marru Joanne u Karl?",
            "qen": "¿A dónde fueron Joanne y Karl?",
            "a": "Marru f'ristorant fl-Imdina.",
            "aen": "Fueron a un restaurante en Mdina."
          },
          {
            "q": "Min ipprova l-fenek?",
            "qen": "¿Quién probó el conejo?",
            "a": "Karl ipprova l-fenek.",
            "aen": "Karl probó el conejo."
          },
          {
            "q": "Meta marru jieklu?",
            "qen": "¿Cuándo fueron a comer?",
            "a": "Marru nhar il-Ħamis.",
            "aen": "Fueron el jueves."
          },
          {
            "q": "X' qasmu wara?",
            "qen": "¿Qué compartieron después?",
            "a": "Qassmu kannol.",
            "aen": "Compartieron un cannolo."
          }
        ]
      }
    },
