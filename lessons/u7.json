      "dialogue": [
        {
          "mt": "Skużani — fejn hu l-bank l-aktar viċin?",
          "en": "Excuse me, where's the nearest bank?"
        },
        {
          "mt": "Bonġu. Imxi sal-pjazza, dur fuq ix-xellug.",
          "en": "Good morning. Walk to the square, turn left."
        },
        {
          "mt": "U mbagħad?",
          "en": "And then?"
        },
        {
          "mt": "Hemmhekk tarah faċċata tal-knisja.",
          "en": "There you'll see it opposite the church."
        },
        {
          "mt": "Grazzi ħafna!",
          "en": "Thank you very much!"
        }
      ],
