    {
      "id": "grammar6",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: doing things",
      "intro": "Comandos, el presente, el futuro y el cotidiano 'tengo' / 'hay'.",
      "rules": [
        {
          "id": "imperative-form",
          "title": "Decirle a alguien qué hacer",
          "explanation": "La forma de comando tiene dos variantes: una persona (Imxi! significa '¡camina!') y un grupo (Imxu!). El grupo suele añadir -u.",
          "letters": [
            "Imxi/Imxu",
            "Ikteb/Iktbu",
            "Dur/Duru",
            "Ikser/Iksru",
            "Mur/Morru",
            "Poġġi/Poġġu"
          ],
          "examples": [
            {
              "mt": "Imxi dritt",
              "en": "Camina recto (a una persona)"
            },
            {
              "mt": "Imxu dritt",
              "en": "Caminen recto (a un grupo)"
            },
            {
              "mt": "Ikteb l-isem tiegħek",
              "en": "Escribe tu nombre (a una persona)"
            },
            {
              "mt": "Iktbu l-isem tagħkom",
              "en": "Escriban su nombre (a un grupo)"
            },
            {
              "mt": "Dur fuq il-lemin",
              "en": "Gira a la derecha (sg)"
            },
            {
              "mt": "Duru fuq il-lemin",
              "en": "Giren a la derecha (pl)"
            }
          ]
        },
        {
          "id": "imperative-from-mamma",
          "title": "La raíz dentro de un comando (avanzado)",
          "explanation": "Para verbos de origen semítico, el imperativo se deriva de la 'mamma' (pasado en 3.ª persona, lo que ÉL hizo) cambiando la primera vocal y la primera consonante raíz. Xorob (él bebió) → ixrob (¡bebe!). El patrón conserva las tres consonantes raíz.",
          "examples": [
            {
              "mt": "Xorob → ixrob / ixorbu",
              "en": "él bebió → ¡bebe! (sg / pl)"
            },
            {
              "mt": "Kiser → ikser / iksru",
              "en": "él rompió → ¡rompe! (sg / pl)"
            },
            {
              "mt": "Ħeles → eħles / eħilsu",
              "en": "él liberó → ¡libera! (sg / pl)"
            },
            {
              "mt": "Kiteb → ikteb / iktbu",
              "en": "él escribió → ¡escribe! (sg / pl)"
            },
            {
              "mt": "Resaq → ersaq / ersqu",
              "en": "él se acercó → ¡acércate! (sg / pl)"
            }
          ]
        },
        {
          "id": "present-from-imperative",
          "title": "Construye el presente desde el comando",
          "explanation": "Toma el comando y añade un prefijo de persona: n- = yo, t- = tú/ella, j- = él (más plurales). Iftaħ! → niftaħ (yo abro), tiftaħ (tú abres), jiftaħ (él abre).",
          "letters": [
            "jien — n",
            "int — t",
            "hu — j",
            "hi — t",
            "aħna — n",
            "intom — t",
            "huma — j"
          ],
          "examples": [
            {
              "mt": "oħroġ → noħroġ",
              "en": "sal (imp) → yo salgo"
            },
            {
              "mt": "oħroġ → toħroġ",
              "en": "→ tú sales / ella sale"
            },
            {
              "mt": "oħroġ → joħroġ",
              "en": "→ él sale"
            },
            {
              "mt": "poġġi → inpoġġi",
              "en": "siéntate (imp, empieza con consonante) → yo me siento"
            },
            {
              "mt": "poġġi → tpoġġi",
              "en": "→ tú te sientas / ella se sienta"
            },
            {
              "mt": "ixrob → nixrob / tixrob / jixrob",
              "en": "beber → yo/tú/él bebe"
            }
          ]
        },
        {
          "id": "future",
          "title": "El futuro es una sola palabra: se",
          "explanation": "Pon se (o ser, o ħa) delante del presente y ya estás en el futuro: Se niekol (voy a comer). Usa se, nunca sa solo (sa solo significa 'hasta').",
          "letters": [
            "se",
            "ser",
            "ħa"
          ],
          "examples": [
            {
              "mt": "Ser nikteb",
              "en": "Voy a escribir"
            },
            {
              "mt": "Se niekol",
              "en": "Voy a comer"
            },
            {
              "mt": "Ħa npoġġi",
              "en": "Voy a sentarme"
            },
            {
              "mt": "Ser jixrob",
              "en": "Él va a beber"
            },
            {
              "mt": "Se naqra",
              "en": "Voy a leer"
            }
          ]
        },
        {
          "id": "ghandi",
          "title": "Decir lo que tienes: Għandi",
          "explanation": "El maltés no tiene un verbo simple 'tener'; usa las mismas terminaciones de posesión de la unidad anterior unidas a għand-: għandi (yo tengo), għandek (tú tienes), għandu (él tiene). 'No tener' lo rodea: m'għandix.",
          "examples": [
            {
              "mt": "Għandi ħin",
              "en": "Tengo tiempo"
            },
            {
              "mt": "Għandek karozza?",
              "en": "¿Tienes un carro?"
            },
            {
              "mt": "M'għandix flus",
              "en": "No tengo dinero"
            }
          ]
        },
        {
          "id": "hemm",
          "title": "Hay: hemm",
          "explanation": "Una sola palabra lo cubre todo: Hemm ħanut hawn? ¿Hay una tienda aquí? La versión negativa es m'hemmx.",
          "examples": [
            {
              "mt": "Hemm problema",
              "en": "Hay un problema"
            },
            {
              "mt": "Hemm żewġ siġġijiet",
              "en": "Hay dos sillas"
            },
            {
              "mt": "M'hemmx ħin",
              "en": "No hay tiempo"
            }
          ]
        },
        {
          "id": "word-order",
          "title": "Construir una oración",
          "explanation": "El orden seguro por defecto es Sujeto–Verbo–Objeto, como en español: Joseph jixrob il-kapuċċino. El maltés puede empezar con el verbo para dar énfasis, pero el orden SVO siempre se entiende.",
          "examples": [
            {
              "mt": "Joseph jixrob il-kapuċċino",
              "en": "Joseph toma el capuchino"
            },
            {
              "mt": "Mary taqra ktieb",
              "en": "Mary lee un libro"
            }
          ]
        }
      ],
