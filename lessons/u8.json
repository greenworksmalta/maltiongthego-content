      "id": "atcafe",
      "icon": "☕",
      "title": "At the café",
      "subtitle": "Fil-kafetterija: ordering a drink and a bite",
      "intro": "Mary and Joseph stop for a coffee. Listen to how they order.",
      "dialogue": [
        {
          "mt": "Bonġu! X'se tieħu?",
          "en": "Good morning! What will you have?"
        },
        {
          "mt": "Nixtieq kapuċċino, jekk jogħġbok.",
          "en": "I'd like a cappuccino, please."
        },
        {
          "mt": "U int, Mary?",
          "en": "And you, Mary?"
        },
        {
          "mt": "Għalija ilma bil-lumi, grazzi.",
          "en": "For me a water with lemon, thanks."
        },
        {
          "mt": "Tridu xi ħaġa tieklu?",
          "en": "Would you like something to eat?"
        },
        {
          "mt": "Iva, żewġ ftajjar, jekk jogħġbok.",
          "en": "Yes, two ftiras, please."
        }
      ]
    },
