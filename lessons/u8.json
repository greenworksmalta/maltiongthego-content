    {
      "id": "grammar8",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: ordering, and saying 'with'",
      "intro": "How to ask, order, and add milk or lemon to anything.",
      "rules": [
        {
          "id": "what-will-you-have",
          "title": "Asking and answering an order",
          "explanation": "Staff ask X'se tieħu? (what will you have?). You answer with Jien nieħu… (I'll have…) or the more polite Nixtieq… (I'd like…). Add jekk jogħġbok to be polite.",
          "examples": [
            {
              "mt": "X'se tieħu?",
              "en": "What will you have?"
            },
            {
              "mt": "Jien nieħu kapuċċino.",
              "en": "I'll have a cappuccino."
            },
            {
              "mt": "Nixtieq ftira, jekk jogħġbok.",
              "en": "I'd like a ftira, please."
            }
          ]
        },
        {
          "id": "with-bil",
          "title": "Saying 'with': bil-",
          "explanation": "To add something, use bil- (with). It follows the same Xemxin/Qamrin rule as the article: before most letters it stays bil- (bil-ħalib, bil-lumi), but before a Xemxin letter it doubles (biz-zokkor, with sugar).",
          "examples": [
            {
              "mt": "kafè bil-ħalib",
              "en": "coffee with milk"
            },
            {
              "mt": "ilma bil-lumi",
              "en": "water with lemon"
            },
            {
              "mt": "kapuċċino biz-zokkor",
              "en": "cappuccino with sugar"
            }
          ]
        }
      ],
      "exercises": [
        {
          "id": "withmc",
          "type": "mc",
          "choices": [
            "bil-",
            "biz-"
          ],
          "items": [
            {
              "word": "kafè ___ ħalib",
              "answer": "bil-",
              "en": "coffee with milk",
              "mt": "kafè bil-ħalib"
            },
            {
              "word": "ilma ___ lumi",
              "answer": "bil-",
              "en": "water with lemon",
              "mt": "ilma bil-lumi"
            },
            {
              "word": "kapuċċino ___ zokkor",
              "answer": "biz-",
              "en": "cappuccino with sugar",
              "mt": "kapuċċino biz-zokkor"
            }
          ],
          "opts": {
            "rawPrompt": true,
            "audioAnswer": true
          }
        }
      ]
    },
