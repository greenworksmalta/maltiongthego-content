          "alt": "Huma",
          "en": "They",
          "icon": "👫"
        }
      ],
      "dialogue": [
        {
          "mt": "Jien naqra ktieb kuljum.",
          "en": "I read a book every day."
        },
        {
          "mt": "Int taqra ħafna?",
          "en": "Do you read a lot?"
        },
        {
          "mt": "Hu jaħdem fl-uffiċċju.",
          "en": "He works at the office."
        },
        {
          "mt": "Hi ssajjar għaġin.",
          "en": "She cooks pasta."
        },
        {
          "mt": "Aħna nimxu fil-ġnien.",
          "en": "We walk in the garden."
        },
        {
          "mt": "Intom titkellmu bil-Malti?",
          "en": "Do you (pl) speak Maltese?"
        },
        {
          "mt": "Huma ġejjin Malta.",
          "en": "They are coming to Malta."
        }
      ],
      "exercises": [
