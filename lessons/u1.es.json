      "passage": {
        "title": "Práctica de lectura: Una mañana en Mosta",
        "lines": [
          {
            "mt": "Kienet ġurnata sabiħa fir-raħal tal-Mosta.",
            "en": "Era un día precioso en el pueblo de Mosta."
          },
          {
            "mt": "Mary qamet kmieni u fetħet it-tieqa.",
            "en": "Mary se levantó temprano y abrió la ventana."
          },
          {
            "mt": "Hi rat ix-xemx u semgħet l-għasafar ikantaw.",
            "en": "Vio el sol y escuchó a los pájaros cantar."
          },
          {
            "mt": "Daħlet ġol-kċina u għamlet il-kapuċċino.",
            "en": "Entró a la cocina y preparó un capuchino."
          },
          {
            "mt": "Wara ħarġet biex tixtri l-ħobż mill-furnar.",
            "en": "Luego salió a comprar pan en la panadería."
          },
          {
            "mt": "Fit-triq iltaqgħet ma' Karl u qaltlu Bonġu.",
            "en": "En la calle se encontró con Karl y le dijo Bonġu."
          },
          {
            "mt": "Kienet ġurnata sabiħa biex titgħallem il-Malti.",
            "en": "Era un día perfecto para aprender maltés."
          }
        ]
      }
    },
