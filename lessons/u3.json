    {
      "id": "grammarhelp",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: being polite and asking for help",
      "intro": "Two small habits carry most of Maltese politeness: stacking short polite words, and the \"Tista'…?\" request.",
      "rules": [
        {
          "id": "polite-formulas",
          "title": "Politeness is stacking",
          "explanation": "Maltese gets more polite by piling small words up. Grazzi is fine; Grazzi ħafna is warmer; open with Skużani to a stranger and close with jekk jogħġbok. Stack as much as the moment needs.",
          "examples": [
            {
              "mt": "Grazzi",
              "en": "Thanks"
            },
            {
              "mt": "Grazzi ħafna",
              "en": "Thanks a lot"
            },
            {
              "mt": "Skużani, tista' tgħinni?",
              "en": "Excuse me, can you help me?"
            },
            {
              "mt": "Iva, jekk jogħġbok",
              "en": "Yes, please"
            },
            {
              "mt": "Le grazzi",
              "en": "No thanks"
            }
          ]
        },
        {
          "id": "language-help",
          "title": "Earn a smile, then switch",
          "explanation": "Nearly everyone here speaks great English, so you can always switch over, but leading with a line of Maltese (Qed nitgħallem il-Malti) buys real goodwill first.",
          "examples": [
            {
              "icon": "🗣️",
              "mt": "Nitkellem ftit Malti",
              "en": "I speak a little Maltese"
            },
            {
              "icon": "📚",
              "mt": "Qed nitgħallem il-Malti",
              "en": "I am learning Maltese"
            },
            {
              "icon": "🇬🇧",
              "mt": "Titkellem bl-Ingliż?",
              "en": "Do you speak English?"
            },
            {
              "mt": "Tista' tirrepeti, bil-mod jekk jogħġbok?",
              "en": "Can you repeat, slowly please?"
            }
          ]
        },
        {
          "id": "tista-requests",
          "title": "Asking with 'Tista'…?'",
          "explanation": "Tista' is just the 'you' form of 'can'. Put any everyday verb after it for a polite request: Tista' tgħinni? (Can you help me?), Tista' tirrepeti? (Can you repeat?), Tista' tiktibha? (Can you write it down?). The full set is nista' (I can), tista' (you can), jista' (he can).",
          "examples": [
            {
              "icon": "🆘",
              "mt": "Tista' tgħinni?",
              "en": "Can you help me?"
            },
            {
              "icon": "🔁",
              "mt": "Tista' tirrepeti?",
              "en": "Can you repeat?"
            },
            {
              "icon": "✍️",
              "mt": "Tista' tiktibha?",
              "en": "Can you write it down?"
            }
          ]
        }
      ]
    },
