    {
      "id": "grammar4",
      "icon": "📖",
      "title": "Grammar",
      "subtitle": "Il-grammatika: making words match",
      "intro": "In Maltese the words around a noun bend to fit it. Here's how colours and adjectives fall into line, and the gender behind it.",
      "rules": [
        {
          "id": "noun-gender",
          "title": "Every noun is a he or a she",
          "explanation": "Maltese has no 'neutral', a table, a car, a book each counts as masculine or feminine, and that choice spreads to the words around it. Rough guide: -a tends feminine (mara, karozza); most other endings lean masculine (raġel, ktieb).",
          "examples": [
            {
              "mt": "raġel",
              "en": "man (m)"
            },
            {
              "mt": "kelb",
              "en": "dog (m)"
            },
            {
              "mt": "nannu",
              "en": "grandfather (m, -u)"
            },
            {
              "mt": "ktieb",
              "en": "book (m)"
            },
            {
              "mt": "mara",
              "en": "woman (f, -a)"
            },
            {
              "mt": "kelba",
              "en": "female dog (f, -a)"
            },
            {
              "mt": "tazza",
              "en": "glass (f, -a)"
            },
            {
              "mt": "karozza",
              "en": "car (f, -a)"
            }
          ]
        },
        {
          "id": "adjective-agreement",
          "title": "Describing words change to match",
          "explanation": "An adjective copies its noun: plain for a he-noun, +a for a she-noun, a reshaped plural for many. Tall → raġel twil / mara twila / tfal twal. And it sits after the noun, not before.",
          "examples": [
            {
              "mt": "raġel twil",
              "en": "a tall man (m)"
            },
            {
              "mt": "mara twila",
              "en": "a tall woman (f)"
            },
            {
              "mt": "tfal twal",
              "en": "tall children (pl)"
            },
            {
              "mt": "ġnien sabiħ",
              "en": "a beautiful garden (m)"
            },
            {
              "mt": "fjura sabiħa",
              "en": "a beautiful flower (f)"
            },
            {
              "mt": "fjuri sbieħ",
              "en": "beautiful flowers (pl)"
            }
          ]
        },
        {
          "id": "colour-agreement",
          "title": "Colours match too",
          "explanation": "Colours are just adjectives: kelb abjad / karozza bajda / ħitan bojod. A few borrowed from Italian (blu, roża, vjola, kannella) never change, easy wins.",
          "letters": [
            "Abjad/Bajda/Bojod",
            "Iswed/Sewda/Suwed",
            "Aħmar/Ħamra/Ħomor",
            "Isfar/Safra/Sofor",
            "Aħdar/Ħadra/Ħodor"
          ],
          "examples": [
            {
              "mt": "kelb abjad",
              "en": "a white dog (m)"
            },
            {
              "mt": "karozza bajda",
              "en": "a white car (f)"
            },
            {
              "mt": "ħitan bojod",
              "en": "white walls (pl)"
            },
            {
              "mt": "ballun aħmar",
              "en": "a red ball (m)"
            },
            {
              "mt": "tuffieħa ħamra",
              "en": "a red apple (f)"
            },
            {
              "mt": "fjuri ħomor",
              "en": "red flowers (pl)"
            },
            {
              "mt": "baħar blu",
              "en": "the blue sea, blu doesn't change"
            }
          ]
        }
      ],
