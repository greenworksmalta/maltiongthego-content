    {
      "id": "present",
      "icon": "🔁",
      "title": "Presente",
      "subtitle": "Il-Preżent: adding a prefix to the imperative",
      "intro": "Añade un prefijo al imperativo para formar el presente. Si el imperativo empieza con vocal: n / t / j / t. Si empieza con consonante: in / t / i / t.",
      "rules": [
        {
          "id": "vowel",
          "title": "El imperativo empieza con vocal: ej. iftaħ (¡abre!)",
          "rows": [
            {
              "person": "Jien (yo)",
              "prefix": "n",
              "form": "niftaħ",
              "en": "yo abro"
            },
            {
              "person": "Int (tú)",
              "prefix": "t",
              "form": "tiftaħ",
              "en": "tú abres"
            },
            {
              "person": "Hu (él)",
              "prefix": "j",
              "form": "jiftaħ",
              "en": "él abre"
            },
            {
              "person": "Hi (ella)",
              "prefix": "t",
              "form": "tiftaħ",
              "en": "ella abre"
            },
            {
              "person": "Aħna (nosotros)",
              "prefix": "n",
              "form": "niftħu",
              "en": "nosotros abrimos"
            },
            {
              "person": "Intom (ustedes)",
              "prefix": "t",
              "form": "tiftħu",
              "en": "ustedes abren"
            },
            {
              "person": "Huma (ellos)",
              "prefix": "j",
              "form": "jiftħu",
              "en": "ellos abren"
            }
          ]
        },
        {
          "id": "consonant",
          "title": "El imperativo empieza con consonante: ej. ġib (¡trae!)",
          "rows": [
            {
              "person": "Jien (yo)",
              "prefix": "in",
              "form": "inġib",
              "en": "yo traigo"
            },
            {
              "person": "Int (tú)",
              "prefix": "t",
              "form": "iġġib",
              "en": "tú traes"
            },
            {
              "person": "Hu (él)",
