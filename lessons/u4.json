      "intro": "Picking what you want by colour and size.",
      "dialogue": [
        {
          "mt": "Skużani, qed infittex qmis ħamra.",
          "en": "Excuse me, I'm looking for a red shirt."
        },
        {
          "mt": "Din il-qmis il-ħamra togħġbok?",
          "en": "Do you like this red shirt?"
        },
        {
          "mt": "Le, grazzi — irrid waħda iżgħar.",
          "en": "No, thanks, I want a smaller one."
        },
        {
          "mt": "U din? Din żgħira u ħamra.",
          "en": "And this one? This is small and red."
        },
        {
          "mt": "Perfetta! Kemm tiswa?",
          "en": "Perfect! How much is it?"
        },
        {
          "mt": "Ħmistax-il ewro.",
          "en": "Fifteen euro."
        },
        {
          "mt": "Bonġu (OTA)",
          "en": "🧪 OTA TEST — tap 🔊, you should hear 'Bonġu' delivered over the air"
        }
      ],
