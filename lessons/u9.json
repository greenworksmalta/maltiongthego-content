      "dialogue": [
        {
          "mt": "Bonġu, x'tixtieq?",
          "en": "Good morning, what would you like?"
        },
        {
          "mt": "Nixtieq kilo tadam, jekk jogħġbok.",
          "en": "I'd like a kilo of tomatoes, please."
        },
        {
          "mt": "Xi ħaġa oħra?",
          "en": "Anything else?"
        },
        {
          "mt": "Iva, ħobża waħda.",
          "en": "Yes, one loaf."
        },
        {
          "mt": "Kemm huma b'kollox?",
          "en": "How much is it all together?"
        },
        {
          "mt": "Żewġ ewro u ħamsin ċenteżmu.",
          "en": "Two euro fifty."
        }
      ]
