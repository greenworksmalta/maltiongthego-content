      "id": "grammar7",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: preguntar y orientarse",
      "intro": "Las palabras interrogativas y la forma cortés de pedir indicaciones.",
      "rules": [
        {
          "id": "wh-questions",
          "title": "Las palabras para preguntar",
          "explanation": "Las partículas interrogativas que necesitas para casi todo: Min (quién), Fejn (dónde), Xiex (qué), Meta (cuándo), Għaliex (por qué), Liema (cuál), Kif (cómo). La mayoría van al principio de la oración.",
          "letters": [
            "Min?",
            "Fejn?",
            "Xi?/Xiex?",
            "Għaliex?/Għala?",
            "Meta?",
            "Liema?",
            "Ta' min?",
            "Kif?"
          ],
          "examples": [
            {
              "mt": "Min hu l-missierek?",
              "en": "¿Quién es tu padre?"
            },
            {
              "mt": "Fejn mort?",
              "en": "¿A dónde fuiste?"
            },
            {
              "mt": "Xi trid tixrob, kapuċċino jew te?",
              "en": "¿Qué quieres tomar, un capuchino o té?"
            },
            {
              "mt": "Għaliex wasalt tard?",
              "en": "¿Por qué llegaste tarde?"
            },
            {
              "mt": "Meta jiftaħ il-ħanut?",
              "en": "¿Cuándo abre la tienda?"
            },
            {
              "mt": "Liema triq twassal il-Belt?",
              "en": "¿Qué calle lleva a Valletta?"
            },
            {
              "mt": "Ta' min hu dan il-lapes?",
              "en": "¿De quién es este lápiz?"
            },
            {
              "mt": "Kif immorru l-ajruport?",
              "en": "¿Cómo vamos al aeropuerto?"
            }
          ]
        },
        {
          "id": "polite-request",
          "title": "Pedir indicaciones con cortesía",
          "explanation": "Un inicio confiable: Skużi. Tista' tgħidli fejn hi…?, jekk jogħġbok. Usa hi/hu según el lugar (hi para l-iskola, hu para il-bank). Cierra con Grazzi.",
          "examples": [
            {
              "mt": "Skużi. Tista' tgħidli fejn hi l-iskola, jekk jogħġbok?",
              "en": "Disculpe. ¿Puede decirme dónde está la escuela, por favor? (f.)"
            },
            {
              "mt": "Skużi. Tista' tgħidli fejn hu l-isptar, jekk jogħġbok?",
              "en": "Disculpe. ¿Puede decirme dónde está el hospital, por favor? (m.)"
            },
            {
              "mt": "Bonġu. Kif nista' nasal il-bank, jekk jogħġbok?",
              "en": "Buenos días. ¿Cómo puedo llegar al banco, por favor?"
            },
            {
              "mt": "Ibqa' sejjer dritt u taraha fuq il-lemin",
              "en": "Sigue recto y lo verás a la derecha"
            },
            {
              "mt": "Grazzi ħafna",
              "en": "Muchas gracias"
            }
          ]
        }
      ]
    },
