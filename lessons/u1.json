      "passage": {
        "title": "Reading practice: A Mosta morning",
        "lines": [
          {
            "mt": "Kienet ġurnata sabiħa fir-raħal tal-Mosta.",
            "en": "It was a lovely day in the village of Mosta."
          },
          {
            "mt": "Mary qamet kmieni u fetħet it-tieqa.",
            "en": "Mary got up early and opened the window."
          },
          {
            "mt": "Hi rat ix-xemx u semgħet l-għasafar ikantaw.",
            "en": "She saw the sun and heard the birds singing."
          },
          {
            "mt": "Daħlet ġol-kċina u għamlet il-kapuċċino.",
            "en": "She went into the kitchen and made a cappuccino."
          },
          {
            "mt": "Wara ħarġet biex tixtri l-ħobż mill-furnar.",
            "en": "Then she went out to buy bread from the baker."
          },
          {
            "mt": "Fit-triq iltaqgħet ma' Karl u qaltlu Bonġu.",
            "en": "On the street she met Karl and said Bonġu to him."
          },
          {
            "mt": "Kienet ġurnata sabiħa biex titgħallem il-Malti.",
            "en": "It was a fine day to learn Maltese."
          }
        ]
      }
