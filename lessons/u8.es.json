    {
      "id": "grammar8",
      "icon": "📖",
      "title": "Gramática",
      "subtitle": "Il-grammatika: pedir, y decir 'con'",
      "intro": "Cómo preguntar, pedir y añadir leche o limón a cualquier cosa.",
      "rules": [
        {
          "id": "what-will-you-have",
          "title": "Hacer y responder un pedido",
          "explanation": "El personal pregunta X'se tieħu? (¿qué va a tomar?). Respondes con Jien nieħu… (voy a tomar…) o la forma más cortés Nixtieq… (quisiera…). Añade jekk jogħġbok para ser cortés.",
          "examples": [
            {
              "mt": "X'se tieħu?",
              "en": "¿Qué va a tomar?"
            },
            {
              "mt": "Jien nieħu kapuċċino.",
              "en": "Voy a tomar un capuchino."
            },
            {
              "mt": "Nixtieq ftira, jekk jogħġbok.",
              "en": "Quisiera una ftira, por favor."
            }
          ]
        },
        {
          "id": "with-bil",
          "title": "Decir 'con': bil-",
          "explanation": "Para agregar algo, usa bil- (con). Sigue la misma regla 'Xemxin'/'Qamrin' que el artículo: antes de la mayoría de las letras se queda como bil- (bil-ħalib, bil-lumi), pero antes de una consonante 'Xemxin' se dobla (biz-zokkor, con azúcar).",
          "examples": [
            {
              "mt": "kafè bil-ħalib",
              "en": "café con leche"
            },
            {
              "mt": "ilma bil-lumi",
              "en": "agua con limón"
            },
            {
              "mt": "kapuċċino biz-zokkor",
              "en": "capuchino con azúcar"
            }
          ]
        }
      ],
      "exercises": [
        {
          "id": "withmc",
          "type": "mc",
          "choices": [
            "bil-",
            "biz-"
          ],
          "items": [
            {
              "word": "kafè ___ ħalib",
              "answer": "bil-",
              "en": "café con leche",
              "mt": "kafè bil-ħalib"
            },
            {
              "word": "ilma ___ lumi",
              "answer": "bil-",
              "en": "agua con limón",
              "mt": "ilma bil-lumi"
            },
            {
              "word": "kapuċċino ___ zokkor",
              "answer": "biz-",
              "en": "capuchino con azúcar",
              "mt": "kapuċċino biz-zokkor"
            }
          ],
          "opts": {
            "rawPrompt": true,
            "audioAnswer": true
          }
        }
      ]
    },
