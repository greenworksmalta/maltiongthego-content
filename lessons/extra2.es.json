    {
      "id": "grammarwelcome",
      "icon": "🇲🇹",
      "title": "Bueno Saber",
      "subtitle": "Algunas cosas que hacen que Malta sea Malta",
      "intro": "No es gramática para memorizar — solo cinco cosas que vale la pena saber antes de empezar. Cada una viene con una frase que puedes usar de verdad.",
      "rules": [
        {
          "id": "two-languages",
          "title": "Dos idiomas, cero estrés",
          "explanation": "Malta tiene DOS idiomas oficiales — el maltés y el inglés. Casi todo el mundo habla un inglés excelente, así que siempre te las arreglarás. Pero unas palabras de maltés te ganan mucha simpatía — a los locales les encanta que los visitantes lo intenten.",
          "examples": [
            {"mt": "Titkellem bl-Ingliż?", "en": "¿Hablas inglés?"},
            {"mt": "Qed nitgħallem il-Malti", "en": "Estoy aprendiendo maltés"},
            {"mt": "Bonġu", "en": "Buenos días"}
          ]
        },
        {
          "id": "one-of-a-kind",
          "title": "El maltés es único",
          "explanation": "El maltés es la única lengua semítica escrita en alfabeto latino, y la única lengua semítica oficial de la UE. Sus raíces son árabes, pero siglos de dominación mezclaron italiano, inglés y francés — así que reconocerás palabras por todas partes.",
          "letters": ["Bonġu (francés)", "Skużi (italiano)", "Strajk (inglés)", "Mela (maltés)"],
          "examples": [
            {"mt": "Bonġu", "en": "Buenos días (del francés 'bonjour')"},
            {"mt": "Skużi", "en": "Perdón (del italiano 'scusi')"},
            {"mt": "Grazzi", "en": "Gracias (del italiano 'grazie')"}
          ]
        },
        {
          "id": "mela",
          "title": "Mela — la palabra más maltesa",
          "explanation": "Si aprendes una palabra, que sea 'Mela'. Significa pues, bueno, claro, por supuesto — y llena casi cualquier hueco en una frase. Los malteses la usan sin parar. Suéltala y sonarás local al instante.",
          "examples": [
            {"mt": "Mela!", "en": "¡Claro! / ¡Por supuesto!"},
            {"mt": "Iva mela", "en": "Sí, claro"},
            {"mt": "Mela ejja", "en": "Venga, vamos"},
            {"mt": "Mela hekk", "en": "Eso es / exacto"}
          ]
        },
        {
          "id": "il-festa",
          "title": "Il-festa — la fiesta del pueblo",
          "explanation": "Cada verano, cada pueblo celebra una 'festa' para su santo patrón: iglesias decoradas, marchas de banda, puestos de comida y fuegos artificiales espectaculares. Si te invitan a una, ve — es Malta en su momento más alegre.",
          "examples": [
            {"mt": "il-festa tar-raħal", "en": "la fiesta del pueblo"},
            {"mt": "il-logħob tan-nar", "en": "los fuegos artificiales"},
            {"mt": "il-banda", "en": "la banda"}
          ]
        },
        {
          "id": "il-the",
          "title": "il- está en todas partes",
          "explanation": "El maltés pega 'el/la' al principio de la palabra como il- (o l-): il-baħar (el mar), il-Belt (la Ciudad). Lo verás en carteles y nombres de lugares por todas las islas. La Lección 1 del curso te muestra exactamente cómo funciona.",
          "letters": ["il-baħar", "il-Belt", "ir-raħal", "ix-xemx"],
          "examples": [
            {"mt": "il-baħar", "en": "el mar"},
            {"mt": "il-Belt", "en": "La Valeta (la Ciudad)"},
            {"mt": "ix-xemx", "en": "el sol"}
          ]
        }
      ]
    },
