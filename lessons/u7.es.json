      "dialogue": [
        {
          "mt": "Skużani — fejn hu l-bank l-aktar viċin?",
          "en": "Disculpe, ¿dónde está el banco más cercano?"
        },
        {
          "mt": "Bonġu. Imxi sal-pjazza, dur fuq ix-xellug.",
          "en": "Buenos días. Camina hasta la plaza, gira a la izquierda."
        },
        {
          "mt": "U mbagħad?",
          "en": "¿Y luego?"
        },
        {
          "mt": "Hemmhekk tarah faċċata tal-knisja.",
          "en": "Allí lo verás frente a la iglesia."
        },
        {
          "mt": "Grazzi ħafna!",
          "en": "¡Muchas gracias!"
        }
