      "title": "En el café",
      "subtitle": "Fil-kafetterija: pedir una bebida y algo para comer",
      "intro": "Mary y Joseph se detienen a tomar un café. Escucha cómo hacen su pedido.",
      "dialogue": [
        {
          "mt": "Bonġu! X'se tieħu?",
          "en": "¡Buenos días! ¿Qué va a tomar?"
        },
        {
          "mt": "Nixtieq kapuċċino, jekk jogħġbok.",
          "en": "Quisiera un capuchino, por favor."
        },
        {
          "mt": "U int, Mary?",
          "en": "¿Y tú, Mary?"
        },
        {
          "mt": "Għalija ilma bil-lumi, grazzi.",
          "en": "Para mí agua con limón, gracias."
        },
        {
          "mt": "Tridu xi ħaġa tieklu?",
          "en": "¿Desean algo de comer?"
        },
        {
          "mt": "Iva, żewġ ftajjar, jekk jogħġbok.",
          "en": "Sí, dos ftiras, por favor."
        }
      ]
    },
